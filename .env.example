# ============================================================
# cook by Receipt — environment variables
# Copy this file to `.env.local` (or set these in your host's
# environment panel) and fill in real values before deploying.
# ============================================================

# --- REQUIRED -------------------------------------------------
# Google Gemini API key. The app throws on startup if missing.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- PRODUCTION ORIGIN GUARD ---------------------------------
# Comma-separated list of origins allowed to call the AI endpoints.
# Requests from any other Origin get HTTP 403.
# The server already defaults to:
#   http://localhost:3000, http://127.0.0.1:3000,
#   https://fridgechef.app, https://www.fridgechef.app
# Only set this if you host on a DIFFERENT domain.
ALLOWED_ORIGINS=https://fridgechef.app,https://www.fridgechef.app

# --- NODE / SERVER -------------------------------------------
NODE_ENV=production
PORT=3000

# --- RATE LIMITS (optional — sensible defaults applied) ------
# Global ceiling across all AI routes, per 15-min window.
GLOBAL_RATE_LIMIT=400
# Per-IP limits on the expensive AI routes, per 1-min window.
PARSE_RATE_LIMIT=15
MEALPLAN_RATE_LIMIT=5
RATE_WINDOW_MS=60000

# --- ANALYTICS (optional — leave empty to disable) ----------
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX).
# When set, gtag.js is injected automatically at runtime.
VITE_GA_ID=
